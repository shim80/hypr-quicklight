# hypr-quiklight default config
# This file is read by the launcher script, not by the C++ binary directly.

output=Xiaomi
device=
brightness=255
fps=60
smoothing=0.35
reverse_top=1
reverse_right=1
reverse_left=0
swap_left_right=0
top_offset=0
right_offset=0
left_offset=0
idle_sleep_ms=0
verbose=0

# Color enhancement
saturation_boost=1.60
value_boost=1.14
gamma=0.93
min_saturation=0.18
hue_shift=0
